# Database (SQLite — file must be writable and persistent on the server)
DATABASE_URL="file:./prisma/dev.db"

# Admin panel login (change in production)
ADMIN_USER="admin"
ADMIN_PASSWORD="demo123"

# Customer session signing — README calls this SESSION_SECRET (recommended in production)
# CUSTOMER_SESSION_SECRET="change-me-to-a-long-random-secret"

# Node sets NODE_ENV=production automatically when using npm start
# PORT is often set by the hosting panel (Hostinger, Render, etc.)
