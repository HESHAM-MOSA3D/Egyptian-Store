# =============================================================================
# قالب متغيرات الإنتاج — انسخ إلى .env على الخادم (لا ترفع .env إلى Git)
# مرجع: PRODUCTION_CHECKLIST.md و DEPLOYMENT.md
# =============================================================================

# --- قاعدة البيانات (إلزامي) ---
# استخدم مساراً مطلقاً ودائماً وقابلاً للكتابة على الخادم.
# Hostinger مثال: file:/home/u123456/domains/example.com/data/production.db
# Railway/Render Volume: file:/data/production.db
DATABASE_URL="file:/absolute/path/to/production.db"

# --- لوحة الإدارة (إلزامي — غيّر الافتراضي) ---
ADMIN_USER="your-admin-username"
ADMIN_PASSWORD="use-a-long-random-password-here"

# --- جلسة التاجر (إلزامي في الإنتاج) ---
# README يذكر أحياناً SESSION_SECRET — الاسم في الكود: CUSTOMER_SESSION_SECRET
# لا تعتمد على ADMIN_PASSWORD كبديل في الإنتاج.
CUSTOMER_SESSION_SECRET="use-another-long-random-secret-here"

# --- تشغيل الخادم ---
# NODE_ENV يُضبط تلقائياً عند npm start / start:prod
NODE_ENV=production
# المنفذ: اضبطه من لوحة الاستضافة (Hostinger / Render / Railway)
PORT=3000

# --- Prisma seed (لا تستخدم على إنتاج حقيقي) ---
# Seed معطّل تلقائياً عند NODE_ENV=production.
# للبيئة تجريبية على السيرفر فقط: ALLOW_SEED=true ثم npx prisma db seed
# ALLOW_SEED=false

# --- اختياري: عنوان التطبيق العام (إن استخدمت reverse proxy) ---
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
